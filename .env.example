# =============================================================================
# AmanaPOS Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=kGv5kMnT0NdXCt9LYJH1pWGzh9ucha6k0TynbkIZgOGnDfn8hCKVahtUrcs55NgWbuI
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me

# Database
DB_NAME=amanapos
DB_USER=amanapos
DB_PASSWORD=amanapos_secret
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# MinIO / S3
USE_S3=True
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=amanapos-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_PUBLIC_BUCKET_NAME=amanapos-public
AWS_S3_PRIVATE_BUCKET_NAME=amanapos-private
AWS_S3_REGION_NAME=us-east-1
AWS_DEFAULT_ACL=private
AWS_S3_CUSTOM_DOMAIN=
# Public URL clients use to access images.
# Dev:  http://localhost:9000  (MinIO port exposed in docker-compose.yml)
# Prod: https://api.amanapos.com/storage  (nginx /storage/ proxy in nginx.prod.conf)
MINIO_PUBLIC_URL=http://localhost:9000

# Image upload limits
MAX_IMAGE_UPLOAD_MB=10

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# OTP
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
# Fixed OTP in DEBUG mode — remove or leave blank in production
DEV_OTP_CODE=123456

# SMS — set SMS_PROVIDER to 'budgetsms', 'twilio', or 'stub'
SMS_PROVIDER=stub
SMS_API_KEY=
SMS_SENDER_ID=AmanaPOS

# Twilio (used when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# BudgetSMS.net (used when SMS_PROVIDER=budgetsms)
# Find these in your BudgetSMS account → API Access
BUDGETSMS_USERNAME=
BUDGETSMS_USERID=
BUDGETSMS_HANDLE=
BUDGETSMS_SENDER_ID=AmanaPOS

# Sentry
SENTRY_DSN=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@amanapos.com

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# App
APP_NAME=AmanaPOS
FRONTEND_URL=http://localhost:3000

OTP_COOLDOWN_SECONDS=60