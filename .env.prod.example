# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.prod and fill in every value.
# NEVER commit .env.prod to version control.
#
# Deploy:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# Run migrations (first deploy or after schema changes):
#   docker compose -f docker-compose.prod.yml --env-file .env.prod exec app python manage.py migrate
# ─────────────────────────────────────────────────────────────────────────────

# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
FRONTEND_URL=https://your-domain.com
APP_NAME=AmanaPOS

# ─── Database (external PostgreSQL at 10.0.0.3) ───────────────────────────────
DB_HOST=10.0.0.3
DB_PORT=5432
DB_NAME=amana_pos
DB_USER=amana_user
DB_PASSWORD=change-me-strong-db-password

# ─── Redis ────────────────────────────────────────────────────────────────────
# IMPORTANT: REDIS_PASSWORD must match in all three lines below.
# The redis container uses this password via --requirepass.
# Django cache and Celery both connect using the full URL.
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-redis-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-me-redis-password@redis:6379/1

# ─── Security ─────────────────────────────────────────────────────────────────
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
SECURE_SSL_REDIRECT=False

# ─── MinIO / S3 Storage ───────────────────────────────────────────────────────
USE_S3=True
AWS_ACCESS_KEY_ID=change-me-minio-access-key
AWS_SECRET_ACCESS_KEY=change-me-minio-secret-key
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_PUBLIC_BUCKET_NAME=amanapos-public
AWS_S3_PRIVATE_BUCKET_NAME=amanapos-private
AWS_STORAGE_BUCKET_NAME=amanapos-media

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
# Test account bypass — remove both lines to disable (leave blank = disabled)
TEST_PHONE=
TEST_OTP=222222

# ─── SMS ──────────────────────────────────────────────────────────────────────
# Set SMS_PROVIDER to 'budgetsms', 'twilio', or 'stub'
SMS_PROVIDER=budgetsms

# BudgetSMS.net (used when SMS_PROVIDER=budgetsms)
BUDGETSMS_USERNAME=your-budgetsms-username
BUDGETSMS_USERID=your-budgetsms-userid
BUDGETSMS_HANDLE=your-budgetsms-handle
BUDGETSMS_SENDER_ID=AmanaPOS

# Twilio (used when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Firebase Push Notifications ──────────────────────────────────────────────
# Enable and supply exactly ONE of the two credential options below.
# Option A — path to service-account JSON file mounted into the container:
#   FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase_service_account.json
# Option B — paste the entire JSON on a single line (escape quotes if needed):
#   FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# NEVER commit the service-account file or its contents to git.
FIREBASE_ENABLED=True
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase_service_account.json
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Sentry (optional — leave blank to disable) ───────────────────────────────
SENTRY_DSN=
GIT_COMMIT_SHA=

# ─── Gunicorn ─────────────────────────────────────────────────────────────────
# These are used by the dev entrypoint fallback only.
# In prod, gunicorn args are explicit in docker-compose.prod.yml.
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# ─── Django Admin ─────────────────────────────────────────────────────────────
ADMIN_URL=your-secret-admin-path/

# ─── Superuser (created on first boot only when both vars are set) ────────────
DJANGO_SUPERUSER_PHONE=+1234567890
DJANGO_SUPERUSER_EMAIL=admin@your-domain.com
DJANGO_SUPERUSER_PASSWORD=change-me-strong-admin-password
DJANGO_SUPERUSER_NAME=Admin
